[user]
	name = Sam J
	email = samjojames@gmail.com

[alias]
	co = checkout
	cm = commit -m
	fp = \\!git fetch origin && git reset --hard origin/$(git branch --show-current)
	w = worktree
	wl = worktree list
	wc = !git-wt-cd
	wf = "!f() { git worktree add -b \"$1\" ../\"$1\" main; }; f"

[init]
	defaultBranch = main

[pull]
	rebase = false

[core]
	editor = nvim
